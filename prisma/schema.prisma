  @@schema("trust")
}

// §3.2 — Trust Score (System-computed; freeze; per-update history) — Doc-6G §3.2 / Doc-4G PassB Part2
// §G5/§H. W3-TRUST-4b realizes the head (`trust_scores`; `score smallint NOT NULL` 0–100 — UNLIKE
// performance's NULLABLE Not-Rated; lifecycle computed|frozen; `band` text) + the append-only per-update
// snapshot (`trust_score_history`). NO in-band write policy — the System Trust-scoring service writes via
// owner-role/SECURITY DEFINER (Invariant #6). FIREWALL (Doc-6G §3.2.1; Invariant #6): NO column computed
// from Financial Tier / Performance / Buyer-Vendor Status and NO cross-score FK — the score CONSUMES
// `verification_records` + `performance_scores` + a fraud read-seam only, and NEVER `verified_financial_tiers`.
// Absence-of-history is NEVER 0 (Doc-3 §12.1 FIXED): a no-input vendor gets a documented NON-ZERO interim
// baseline (the formula plug's [ESC-TRUST-POLICY] concern). `vendor_profile_id` is a bare cross-module UUID
// (→ M2; no FK). The index + immutability triggers + RLS + the ONE SD write function live raw-SQL in the
// `trust_trust_scoring` migration; `ScoreFreezeState` is SHARED with the performance tables (declared once,
// in `trust_performance_scoring` / below). Columns/enum labels [Doc-2 §10.6 / Doc-6G §3.2 binding]; [§2.5].

// §3.2.1 — trust.trust_scores (head; score smallint NOT NULL 0–100; lifecycle computed|frozen; System-written)
model TrustScore {
  id                  String           @id @db.Uuid
  vendorProfileId     String           @unique(map: "trust_scores_vendor_uq") @map("vendor_profile_id") @db.Uuid
  score               Int              @db.SmallInt
  band                String
  trustFormulaVersion String           @map("trust_formula_version")
  trustScoreUpdatedAt DateTime         @default(now()) @map("trust_score_updated_at") @db.Timestamptz
  freezeState         ScoreFreezeState @default(none) @map("freeze_state")
  freezeReason        String?          @map("freeze_reason")
  frozenAt            DateTime?        @map("frozen_at") @db.Timestamptz
  createdAt           DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime         @updatedAt @map("updated_at") @db.Timestamptz
  createdBy           String?          @map("created_by") @db.Uuid
  updatedBy           String?          @map("updated_by") @db.Uuid

  history TrustScoreHistory[]

  @@map("trust_scores")
  @@schema("trust")
}

// §3.2.2 — trust.trust_score_history (append-only; per-update snapshot; in-module FK → trust_scores)
model TrustScoreHistory {
  id                  String   @id @db.Uuid
  trustScoreId        String   @map("trust_score_id") @db.Uuid
  vendorProfileId     String   @map("vendor_profile_id") @db.Uuid
  score               Int      @db.SmallInt
  band                String
  trustFormulaVersion String   @map("trust_formula_version")
  snapshotAt          DateTime @default(now()) @map("snapshot_at") @db.Timestamptz
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz
  createdBy           String?  @map("created_by") @db.Uuid

  trustScore TrustScore @relation(fields: [trustScoreId], references: [id], map: "trust_score_history_score_fk")

  @@index([vendorProfileId, snapshotAt], map: "trust_score_history_vendor_idx")
  @@map("trust_score_history")
  @@schema("trust")
}

// §3.3 — Performance Scoring (System-computed; idempotent inputs; per-update history) — Doc-6G §3.3 /
// Doc-4G PassB Part3 §G6/§H. W3-TRUST-4a realizes the head (`performance_scores`; NULLABLE score = Not
// Rated below the 5-responses-OR-2-projects min-threshold gate — never 0), the append-only per-update
// snapshot (`performance_score_history`), and the idempotent Operations/RFQ consumer inputs
// (`performance_inputs`; dedup UNIQUE on (source_type, source_entity_id, input_type)). NO in-band write
// policy — the System Performance-scoring service writes via owner-role/SECURITY DEFINER (Invariant #6).
// FIREWALL (Doc-6G §3.3.1 line 84): components_jsonb carries performance inputs ONLY — no Financial Tier /
// Trust Score / Buyer-Vendor Status column or FK. `vendor_profile_id`/`source_entity_id` are bare
// cross-module UUIDs (→ M2/M3/M4; no FK). The 3 enums + indexes + immutability triggers + RLS + the SD
// write functions live raw-SQL in the `trust_performance_scoring` migration. Columns/enum labels are
// [Doc-2 §10.6 / Doc-6G §3.3 binding]; physical specifics [§2.5].

// §3.3.1 — trust.performance_scores (head; NULLABLE score = Not Rated; min-threshold gate; System-written)
model PerformanceScore {
  id                        String           @id @db.Uuid
  vendorProfileId           String           @unique(map: "performance_scores_vendor_uq") @map("vendor_profile_id") @db.Uuid
  score                     Int?             @db.SmallInt
  level                     String?
  componentsJsonb           Json?            @map("components_jsonb") @db.JsonB
  performanceFormulaVersion String           @map("performance_formula_version")
  performanceScoreUpdatedAt DateTime         @default(now()) @map("performance_score_updated_at") @db.Timestamptz
  freezeState               ScoreFreezeState @default(none) @map("freeze_state")
  freezeReason              String?          @map("freeze_reason")
  frozenAt                  DateTime?        @map("frozen_at") @db.Timestamptz
  minThresholdMet           Boolean          @default(false) @map("min_threshold_met")
  createdAt                 DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt                 DateTime         @updatedAt @map("updated_at") @db.Timestamptz
  createdBy                 String?          @map("created_by") @db.Uuid
  updatedBy                 String?          @map("updated_by") @db.Uuid

  history PerformanceScoreHistory[]

  @@map("performance_scores")
  @@schema("trust")
}

// §3.3.2 — trust.performance_score_history (append-only; per-update snapshot; in-module FK → performance_scores)
model PerformanceScoreHistory {
  id                        String   @id @db.Uuid
  performanceScoreId        String   @map("performance_score_id") @db.Uuid
  vendorProfileId           String   @map("vendor_profile_id") @db.Uuid
  score                     Int?     @db.SmallInt
  level                     String?
  performanceFormulaVersion String   @map("performance_formula_version")
  snapshotAt                DateTime @default(now()) @map("snapshot_at") @db.Timestamptz
  createdAt                 DateTime @default(now()) @map("created_at") @db.Timestamptz
  createdBy                 String?  @map("created_by") @db.Uuid

  performanceScore PerformanceScore @relation(fields: [performanceScoreId], references: [id], map: "performance_score_history_score_fk")

  @@map("performance_score_history")
  @@schema("trust")
}

// §3.3.3 — trust.performance_inputs (append-only; idempotent Operations/RFQ consumer; dedup UNIQUE; NO SD-edit)
model PerformanceInput {
  id              String                @id @db.Uuid
  vendorProfileId String                @map("vendor_profile_id") @db.Uuid
  sourceEntityId  String                @map("source_entity_id") @db.Uuid
  sourceType      PerformanceSourceType @map("source_type")
  inputType       PerformanceInputType  @map("input_type")
  occurredAt      DateTime              @map("occurred_at") @db.Timestamptz
  valueJsonb      Json?                 @map("value_jsonb") @db.JsonB
  createdAt       DateTime              @default(now()) @map("created_at") @db.Timestamptz
  createdBy       String?               @map("created_by") @db.Uuid

  @@unique([sourceType, sourceEntityId, inputType], map: "performance_inputs_dedup_uq")
  @@index([vendorProfileId, inputType, occurredAt], map: "performance_inputs_vendor_idx")
  @@map("performance_inputs")
  @@schema("trust")
}

enum ScoreFreezeState {
  none
  frozen

  @@map("score_freeze_state")
  @@schema("trust")
}

enum PerformanceInputType {
  response
  decline
  non_response
  delivery
  feedback
  dispute
  completion

  @@map("performance_input_type")
  @@schema("trust")
}

enum PerformanceSourceType {
  invitation
  quotation
  engagement
  wcc

  @@map("performance_source_type")
  @@schema("trust")
}

// §3.4 — trust.fraud_signals (platform-internal; polymorphic subject; admin/System FOR ALL — NO SD; emits
// NO event — Doc-2 §8 has no Trust fraud event). W3-TRUST-4c realizes the BC-TRUST-4 aggregate (substrate +
// in-band audited-write lifecycle in the `trust_fraud_signals` migration + the M5 fraud-signal service).
// `subject_id`/`reported_by`/`created_by`/`updated_by` are bare cross-module UUIDs (Doc-2 §0.3; no FK).
// `subjectType`/`signalType`/`severity` are TEXT — Doc-2 §10.6 declares no value set (validated non-empty in
// the app layer; membership `[ESC]`-deferred, no fixed enum coined). NO CHECK, NO business UNIQUE, and NO
// detection_ref/triage_note column (Doc-4G §H.10 — Pass-B introduces no column; the request fields
// detection_ref/triage_note ride the immutable AUDIT `newValue`). The 2 indexes + the column-scoped
// immutability trigger (identity + creation facts frozen; DELETE blocked) + the `fraud_signals_admin FOR ALL`
// RLS live raw-SQL in the migration (the house pattern). Columns/enum labels [Doc-2 §10.6 / Doc-6G §3.4 binding].
model FraudSignal {
  id          String          @id @db.Uuid
  subjectId   String          @map("subject_id") @db.Uuid
  subjectType String          @map("subject_type")
  reportedBy  String?         @map("reported_by") @db.Uuid
  signalType  String          @map("signal_type")
  severity    String
  state       FraudSignalState @default(open)
  createdAt   DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime        @updatedAt @map("updated_at") @db.Timestamptz
  createdBy   String?         @map("created_by") @db.Uuid
  updatedBy   String?         @map("updated_by") @db.Uuid

  // Indexes (subject lookup + the partial `open/reviewed` work-queue) live raw-SQL in the
  // `trust_fraud_signals` migration (the WP1 verification_records precedent — partial predicates are
  // not expressible via Prisma `@@index`; kept in one place, the migration).
  @@map("fraud_signals")
  @@schema("trust")
}

enum FraudSignalState {
  open
  reviewed
  actioned
  dismissed

  @@map("fraud_signal_state")
  @@schema("trust")
}

