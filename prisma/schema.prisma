// Doc-6C_GrowthInvitation_Patch_v1.0.4 §2 — identity.growth_invitations (the issued growth-invite
// artifact; GI-2 immutable core — the at-create column trigger, the partial-unique-live token_hash
// index, Band-H indexes and RLS live raw-SQL-only in the `identity_growth_hub` migration; the house
// pattern for constraints Prisma cannot express). SD=YES.
model GrowthInvitation {
  id                     String                @id @db.Uuid
  referrerOrganizationId String                @map("referrer_organization_id") @db.Uuid
  campaignKey            String                @map("campaign_key")
  recipientType          GrowthRecipientType   @map("recipient_type")
  recipientIdentifier    String?               @map("recipient_identifier")
  tokenHash              String                @map("token_hash")
  maxRedemptions         Int?                  @map("max_redemptions")
  redemptionCount        Int                   @default(0) @map("redemption_count")
  state                  GrowthInvitationState @default(issued)
  expiresAt              DateTime              @map("expires_at") @db.Timestamptz
  createdAt              DateTime              @default(now()) @map("created_at") @db.Timestamptz
  updatedAt              DateTime              @updatedAt @map("updated_at") @db.Timestamptz
  createdBy              String?               @map("created_by") @db.Uuid
  updatedBy              String?               @map("updated_by") @db.Uuid
  deletedAt              DateTime?             @map("deleted_at") @db.Timestamptz
  deletedBy              String?               @map("deleted_by") @db.Uuid
  deleteReason           String?               @map("delete_reason")

  referrerOrganization Organization            @relation(fields: [referrerOrganizationId], references: [id], map: "growth_invitations_referrer_fk")
  conversions          InvitationConversion[]
  deliveryRefs         InvitationDeliveryRef[]

  @@map("growth_invitations")
  @@schema("identity")
}

enum GrowthInvitationState {
  issued
  expired
  revoked

  @@map("growth_invitation_state")
  @@schema("identity")
}

enum GrowthRecipientType {
  email
  sms
  whatsapp
  link
  qr

  @@map("growth_recipient_type")
  @@schema("identity")
}

// Doc-6C_GrowthInvitation_Patch_v1.0.4 §3 — identity.invitation_conversions (the attribution
// record; APPEND-ONLY, Inv #8 — NO soft-delete tuple; the block_delete / at-create triggers, the
// 5.12 shape CHECK, Band-H indexes and RLS live raw-SQL-only in the `identity_growth_hub`
// migration). `referrer_organization_id` is the ONE documented denormalized tenant anchor (Rec-2).
model InvitationConversion {
  id                     String                    @id @db.Uuid
  growthInvitationId     String                    @map("growth_invitation_id") @db.Uuid
  referrerOrganizationId String                    @map("referrer_organization_id") @db.Uuid
  referredOrganizationId String?                   @map("referred_organization_id") @db.Uuid
  state                  InvitationConversionState @default(started)
  startedAt              DateTime                  @default(now()) @map("started_at") @db.Timestamptz
  registeredAt           DateTime?                 @map("registered_at") @db.Timestamptz
  createdAt              DateTime                  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt              DateTime                  @updatedAt @map("updated_at") @db.Timestamptz
  createdBy              String?                   @map("created_by") @db.Uuid
  updatedBy              String?                   @map("updated_by") @db.Uuid

  growthInvitation     GrowthInvitation @relation(fields: [growthInvitationId], references: [id], map: "invitation_conversions_invitation_fk")
  referrerOrganization Organization     @relation("ConversionReferrer", fields: [referrerOrganizationId], references: [id], map: "invitation_conversions_referrer_fk")
  referredOrganization Organization?    @relation("ConversionReferred", fields: [referredOrganizationId], references: [id], map: "invitation_conversions_referred_fk")

  @@map("invitation_conversions")
  @@schema("identity")
}

enum InvitationConversionState {
  started
  registered

  @@map("invitation_conversion_state")
  @@schema("identity")
}

// The §10.3-class OPERATIONAL delivery-reference store (Doc-6C v1.0.4 §5 — service-layer state,
// NOT a Doc-2 aggregate; the CHK-6-072 idempotency-store class). P1 holds ONLY the
// reference→invitation mapping — NO token material ("raw token is never stored", Doc-2 v1.0.10 §1,
// holds absolutely); the token-material/nonce/TTL legs are the Board-recorded P2 carry (the
// `[ESC-6-API]` flag covers the store's physical shape only). Staff-GUC-only RLS, raw SQL in the
// migration.
model InvitationDeliveryRef {
  deliveryReferenceId String   @id @map("delivery_reference_id") @db.Uuid
  growthInvitationId  String   @map("growth_invitation_id") @db.Uuid
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz

  growthInvitation GrowthInvitation @relation(fields: [growthInvitationId], references: [id], map: "invitation_delivery_refs_invitation_fk")

  secret   InvitationDeliverySecret?
  urlNonces InvitationDeliveryUrlNonce[]

  @@map("invitation_delivery_refs")
  @@schema("identity")
}

// W3-COMM-GRW-1 (B2-2) — the §C13 SECURE DELIVERY STORE (M1-owned; the P1 Board carry). Two
// §10.3-class OPERATIONAL stores riding the Doc-6C v1.0.4 §5 `[ESC-6-API]` physical-shape marker
// (semantics pinned by the folded Doc-4C v1.0.3 §C13 + Doc-3 v1.14 — never re-authored here):
//   • invitation_delivery_secrets — token CIPHERTEXT + nonce (AES-256-GCM; key from env, never
//     logged) written by `create_invitation` in the SAME issuing txn (targeted only). The raw token
//     is recoverable ONLY for signed-URL minting inside `resolve_invitation_delivery_payload`
//     (M6 sole caller); the plaintext-never-persisted rule holds (Doc-2 v1.0.10 §1).
//   • invitation_delivery_url_nonces — the ONE-TIME signed-URL replay state (lifetime =
//     `identity.growth_invite_delivery_url_ttl`, the seeded 15m POLICY key; consumed on first
//     redemption — the §C13 replay guard).
// Staff-GUC-only RLS (service plumbing, never a tenant surface) — raw SQL in the
// `identity_growth_delivery_store` migration. NOT Doc-2 aggregates; regenerable operational state.
model InvitationDeliverySecret {
  deliveryReferenceId String   @id @map("delivery_reference_id") @db.Uuid
  tokenCiphertext     String   @map("token_ciphertext")
  tokenNonce          String   @map("token_nonce")
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz

  deliveryRef InvitationDeliveryRef @relation(fields: [deliveryReferenceId], references: [deliveryReferenceId], map: "invitation_delivery_secrets_ref_fk")

  @@map("invitation_delivery_secrets")
  @@schema("identity")
}

model InvitationDeliveryUrlNonce {
  id                  String    @id @db.Uuid
  deliveryReferenceId String    @map("delivery_reference_id") @db.Uuid
  expiresAt           DateTime  @map("expires_at") @db.Timestamptz
  consumedAt          DateTime? @map("consumed_at") @db.Timestamptz
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz

  deliveryRef InvitationDeliveryRef @relation(fields: [deliveryReferenceId], references: [deliveryReferenceId], map: "invitation_delivery_url_nonces_ref_fk")

  @@index([deliveryReferenceId], map: "invitation_delivery_url_nonces_ref_idx")
  @@map("invitation_delivery_url_nonces")
  @@schema("identity")
}
