# iVendorz — environment template (Wave 0 bootstrap).
# Copy to `.env.local` and fill real values. NEVER commit real secrets (CLAUDE.md §2).
# Env vars only; secrets never in code, commits, or logs.

# --- Database (Supabase PostgreSQL; one schema per module via Prisma multiSchema) ---
# Pooled connection (app runtime) and direct connection (migrations).
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# --- Supabase (Auth / Storage / Realtime) ---
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR-ANON-KEY"
SUPABASE_SERVICE_ROLE_KEY="YOUR-SERVICE-ROLE-KEY"

# --- Inngest (async jobs; consume M0 outbox events) ---
INNGEST_EVENT_KEY="YOUR-INNGEST-EVENT-KEY"
INNGEST_SIGNING_KEY="YOUR-INNGEST-SIGNING-KEY"

# --- Email (Resend) ---
RESEND_API_KEY="YOUR-RESEND-API-KEY"

# --- Analytics (PostHog) ---
NEXT_PUBLIC_POSTHOG_KEY="YOUR-POSTHOG-KEY"
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"
