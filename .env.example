# iVendorz — environment variable template (WP-0.12 [W0-SEC-001]).
#
# Copy to `.env.local` and fill real values for local dev. NEVER commit real secrets —
# env vars only; secrets never in code/commits/logs (CLAUDE.md §2). `.env.local` (and all
# `.env*` except this template) are gitignored. This file lists NAMES only, no values.
#
# Real Supabase project + production secrets are wired at Wave 1 (deferred). For local dev
# the test harness uses the docker-compose Postgres (see docker-compose.yml).

# --- Database (Prisma / Supabase Postgres) ---------------------------------------------
# Pooled connection for the app runtime; DIRECT_URL is the direct (non-pooler) connection
# used for migrations (Prisma migrate must NOT go through the Supabase pgbouncer pooler).
DATABASE_URL=
DIRECT_URL=

# --- Supabase (Auth / Storage / Realtime) ----------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only privileged key — NEVER exposed to the browser bundle. Used by privileged
# server operations in later waves; not wired at bootstrap.
SUPABASE_SERVICE_ROLE_KEY=

# --- Inngest (async jobs) --------------------------------------------------------------
# Read by the Inngest SDK at runtime. SIGNING_KEY verifies request signatures and MUST be
# set in production before real job functions are registered (Wave 2).
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# --- Email (Resend) --------------------------------------------------------------------
RESEND_API_KEY=

# --- Analytics (PostHog) ---------------------------------------------------------------
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# --- AI (future activation — Claude + OpenAI) ------------------------------------------
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Growth invitation delivery store (M1 · W3-COMM-GRW-1 B2-2) -------------------------
# RUNTIME-REQUIRED — release-readiness prerequisite, not an optional feature toggle.
#
# WHAT: the AES-256-GCM key that encrypts the invitation token AT REST
# (`identity.invitation_delivery_secrets`) so the M6 delivery path can recover it solely to mint
# one-time, short-lived signed URLs. The raw token is never stored in plaintext, never logged, and
# never returned to any caller outside that signed URL. The URL-SIGNING key is DERIVED from this
# same value (SHA-256 domain separation) — one secret, two purposes.
#
# FORMAT: exactly 32 bytes, supplied as 64 hex characters or as base64 that decodes to 32 bytes.
# Anything else is treated as absent. Generate one with:  openssl rand -hex 32
#
# FAILURE MODE (deterministic + visible, never a silent degrade): if absent or malformed, a
# TARGETED `create_invitation` throws inside the issuing transaction — the whole create ROLLS BACK
# and no invitation is issued. The platform never emits an undeliverable invitation. Invitations
# already stored resolve to the transient `identity_growth_invite_delivery_unavailable` path.
#
# SERVER-ONLY: deliberately NOT `NEXT_PUBLIC_*` — it must never reach the browser bundle, and it is
# never logged, never persisted, and never included in any response or error message.
#
# ROTATION (state of the code, not an aspiration): there is NO key versioning — stored ciphertext
# carries no key id, so a value can only be decrypted with the key that encrypted it. Rotating
# WITHOUT re-encrypting the existing rows leaves previously-issued targeted invitations
# undeliverable (their resolve returns the transient unavailable path) while newly issued ones work
# normally. A re-encryption / key-versioning procedure is a FOLLOW-UP — do not assume one exists.
#
# PROVISIONING OWNERSHIP: local dev — each developer generates their own throwaway value; CI — a
# clearly-labelled non-production test value set in `.github/workflows/ci.yml`; staging/production —
# the platform/infrastructure owner provisions a unique value per environment via the hosting
# secret store (never committed, never shared across environments).
GROWTH_INVITE_DELIVERY_STORE_KEY=

# --- Frontend demo mode (Architecture Board ruling 2026-07-15 #4) -----------------------
# `1` lets the presentation-only `(app)` tree render WITHOUT a Supabase session, preserving the
# approved clickable-demo / prototype review workflow (`app/(app)/layout.tsx`). Server-only —
# deliberately NOT `NEXT_PUBLIC_*`, so it never reaches the browser bundle.
#
# FAIL-SAFE: ignored when `VERCEL_ENV=production`, so a stray `1` in production can never unlock
# the authenticated tree. Leave EMPTY unless you are running the local demo.
IVENDORZ_DEMO_MODE=
